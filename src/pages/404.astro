---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <section class="mx-auto flex max-w-3xl flex-col items-start gap-4 px-6 py-32">
    <p class="text-muted-foreground font-mono text-xs">404</p>
    <h1 class="font-display text-foreground text-3xl font-medium">This page doesn't exist.</h1>
    <p class="text-muted-foreground">The link might be broken, or the page may have moved.</p>
    <a href="/" class="text-primary font-mono text-sm hover:underline">← Back home</a>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import { SITE } from '@/site.config';

const tools = ['TypeScript', 'React', 'Node.js', 'Tailwind CSS', 'Web Fundamentals'];
---

<BaseLayout title="About" description={`A bit about ${SITE.name} and how they work.`}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-24 sm:pt-24">
    <p class="text-ink-soft mb-6 font-mono text-xs">About</p>

    <h1 class="font-display text-ink max-w-xl text-3xl font-medium sm:text-4xl">
      {SITE.role}.
    </h1>

    <div class="prose prose-sm sm:prose-base mt-8 max-w-xl">
      <p>
        With over 10 years of experience in the software industry, I've worn many hats from software
        development to software testing for long-running SaaS projects.
      </p>
      <p>
        As a former tester, I spend a lot of my time thinking about the user's journey through a
        system to ensure the best experience.
      </p>
      <!-- <p> -->
      <!--   I start most projects by trying to find the smallest version of the problem — the one -->
      <!--   screen, one flow, or one fix that actually matters — and build that first, properly, before -->
      <!--   expanding outward. -->
      <!-- </p> -->
      <!-- <p> -->
      <!--   That usually means fewer features than a kickoff deck promises, and more attention to the -->
      <!--   parts people interact with constantly: load times, empty states, error messages, the things -->
      <!--   that quietly decide whether software feels good to use. -->
      <!-- </p> -->
      <!-- <p> -->
      <!--   Outside of client and product work, I maintain a couple of small open-source tools and write -->
      <!--   occasional notes on what I learn building them. -->
      <!-- </p> -->
    </div>

    <div class="mt-10">
      <p class="text-ink-soft mb-3 font-mono text-xs">Tools</p>
      <ul class="flex flex-wrap gap-2">
        {
          tools.map((tool) => (
            <li class="border-line text-ink-soft rounded-md border px-3 py-1 font-mono text-xs">
              {tool}
            </li>
          ))
        }
      </ul>
    </div>

    <Button href={`mailto:${SITE.email}`} class="mt-10">Get in touch</Button>
  </section>
</BaseLayout>

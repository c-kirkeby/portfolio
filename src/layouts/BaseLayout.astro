---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/site.config';
import '@/styles/global.css';
import BaseHead from '@/components/BaseHead.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = SITE.description, image = '/og-image.png' } = Astro.props;
---

<!doctype html>
<html lang={SITE.locale} class="min-h-screen">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body id="top" class="bg-background text-foreground flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { title, summary, date, tags } = entry.data;

const stamp = `${date.getFullYear()} · ${String(date.getMonth() + 1).padStart(2, '0')}`;
---

<a
  href={`/work/${entry.id}`}
  class="group border-border hover:border-primary grid grid-cols-[3.5rem_1fr_auto] items-center gap-4 border-b py-5 transition-colors sm:grid-cols-[4.5rem_1fr_auto] sm:gap-6"
>
  <span class="text-muted-foreground font-mono text-xs">{stamp}</span>

  <span class="min-w-0">
    <span
      class="font-display text-foreground group-hover:text-primary block truncate text-lg transition-colors"
    >
      {title}
    </span>
    <span class="text-muted-foreground hidden truncate text-sm sm:block">{summary}</span>
  </span>

  <span class="flex items-center gap-4">
    <span class="text-muted-foreground hidden font-mono text-[11px] md:block">
      {tags.slice(0, 2).join(' · ')}
    </span>
    <span
      aria-hidden="true"
      class="text-muted-foreground group-hover:text-primary transition-all group-hover:translate-x-1"
    >
      →
    </span>
  </span>
</a>
